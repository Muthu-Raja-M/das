# ==============================================================================
# BLUE CONNECT - API ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================

# Database Connection Settings
# Configured default engine is PostgreSQL.
DB_NAME=blue_connect_db
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_HOST=localhost
DB_PORT=5432

# Third-Party Integrations
# SendGrid API Key and Default Sender Email for Password Recovery OTPs.
SENDGRID_API_KEY=SG.your_sendgrid_key_here
FROM_EMAIL=your_verified_sender_email@domain.com

# Django Security Configurations
# SECRET_KEY=django-insecure-...
# DEBUG=True
# ALLOWED_HOSTS=127.0.0.1,localhost
